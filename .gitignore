# ────────────────────────────────────────────────────────────────
# ArenaVerse – Root .gitignore
# ────────────────────────────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/
.next/
out/

# Environment files (never commit real secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Prisma client & migrations lock
backend/src/generated/
backend/prisma/migrations/**/migration_lock.toml

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# Test coverage
coverage/
.nyc_output/

# Cache
.cache/
.parcel-cache/
*.tsbuildinfo

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo

# Docker volumes (local)
pgdata/
redis_data/

# k6 results
k6_results/
